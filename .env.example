# Environment Variables — TruckLogis Thailand
# Copy this file to .env and fill in real values
# DO NOT commit .env to GitHub — it's already in .gitignore

# ── HERE Maps (Free tier: 250,000 calls/month) ──────────────────────────────
# สมัครที่ https://developer.here.com → Create Project → Generate API Key
HERE_API_KEY=your_here_api_key_here

# ── PTT OilPrice API (ถ้ามี) ─────────────────────────────────────────────────
# ติดต่อ PTT เพื่อขอ API access
PTT_API_KEY=optional_ptt_api_key

# ── App Config ───────────────────────────────────────────────────────────────
# URL ของ app เมื่อ deploy (เช่น https://trucklogis.netlify.app)
PUBLIC_URL=https://your-site.netlify.app

# Comma-separated origins allowed to call HERE proxy functions.
# Same-origin Netlify requests are allowed automatically.
ALLOWED_ORIGINS=https://your-site.netlify.app

# Per-function in-memory safety limit. Use Netlify/edge protections for stronger quotas.
HERE_RATE_LIMIT_PER_MINUTE=60
